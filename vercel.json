{
  "buildCommand": "python manage.py collectstatic --noinput",
  "outputDirectory": "",
  "installCommand": "pip install -r requirements.txt",
  "builds": [
    {
      "src": "bhola/wsgi.py",
      "use": "@vercel/python",
      "config": {
        "runtime": "python3.12"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "bhola/wsgi.py"
    }
  ]
}